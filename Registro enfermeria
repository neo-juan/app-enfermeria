<script>
(function() {
  'use strict';

  var registros = [];
  var editingId = null;
  var sheetsConfig = { url: '', auto: false };

  function $(id) { return document.getElementById(id); }

  function guardar() {
    try {
      localStorage.setItem('enfermeriaRegistros', JSON.stringify(registros));
    } catch(e) { console.error('Error al guardar:', e); }
  }

  function toast(msg, tipo) {
    var t = $('toast');
    if (!t) return;
    t.textContent = msg;
    var cls = 'toast show';
    if (tipo === 'error') cls += ' error';
    if (tipo === 'warning') cls += ' warning';
    t.className = cls;
    setTimeout(function() { t.className = 'toast'; }, 3500);
  }

  function setHoraActual(id) {
    var ahora = new Date();
    var h = String(ahora.getHours()).padStart(2, '0');
    var m = String(ahora.getMinutes()).padStart(2, '0');
    var el = $(id);
    if (el) el.value = h + ':' + m;
  }

  function cambiarTab(tab) {
    var allTabs = document.querySelectorAll('.tab');
    for (var i = 0; i < allTabs.length; i++) allTabs[i].classList.remove('active');
    
    var tabBtn = document.querySelector('[data-tab="' + tab + '"]');
    if (tabBtn) tabBtn.classList.add('active');

    var contents = document.querySelectorAll('.tab-content');
    for (var j = 0; j < contents.length; j++) contents[j].style.display = 'none';
    
    var tabContent = $('tab-' + tab);
    if (tabContent) tabContent.style.display = 'block';

    if (tab === 'hoy') renderHoy();
    if (tab === 'historial') renderHistorial();
  }

  function formatearFecha(f) {
    if (!f) return '';
    var p = f.split('-');
    var meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
    return parseInt(p[2]) + ' de ' + meses[parseInt(p[1])-1] + ' de ' + p[0];
  }

  function escapar(t) {
    if (!t) return '';
    var div = document.createElement('div');
    div.textContent = String(t);
    return div.innerHTML;
  }

  // ===== GOOGLE SHEETS =====
  function actualizarIndicadorSheets() {
    var ind = $('zapierIndicator');
    if (!ind) return;
    if (sheetsConfig.url && sheetsConfig.auto) {
      ind.innerHTML = '<span class="zapier-status connected" style="background:#10b981;">📊 Google Sheets conectado · Auto-envío ON</span>';
    } else if (sheetsConfig.url) {
      ind.innerHTML = '<span class="zapier-status connected" style="background:#10b981;">📊 Google Sheets conectado · Manual</span>';
    } else {
      ind.innerHTML = '<span class="zapier-status disconnected">📊 Google Sheets desconectado</span>';
    }
  }

  function guardarConfigSheets() {
    var url = $('sheetsUrl').value.trim();
    var auto = $('sheetsAuto').checked;
    if (url && url.indexOf('script.google.com') === -1) {
      toast('La URL no parece ser de Google Apps Script', 'error');
      return;
    }
    sheetsConfig.url = url;
    sheetsConfig.auto = auto;
    try {
      localStorage.setItem('enfermeriaSheets', JSON.stringify(sheetsConfig));
    } catch(e) {}
    actualizarIndicadorSheets();
    toast('✓ Configuración guardada');
  }

  function desconectarSheets() {
    if (!confirm('¿Desconectar Google Sheets?')) return;
    sheetsConfig = { url: '', auto: false };
    try {
      localStorage.setItem('enfermeriaSheets', JSON.stringify(sheetsConfig));
    } catch(e) {}
    $('sheetsUrl').value = '';
    $('sheetsAuto').checked = false;
    actualizarIndicadorSheets();
    toast('Google Sheets desconectado');
  }

  function enviarASheets(registro, silencioso) {
    return new Promise(function(resolve) {
      var url = sheetsConfig.url;
      if (!url) {
        if (!silencioso) toast('Configura primero la URL de Apps Script', 'error');
        resolve(false);
        return;
      }
      var payload = {
        fecha: registro.fecha,
        hora_llegada: registro.horaLlegada,
        nombre_estudiante: registro.nombre,
        grado_grupo: registro.grado,
        tipo_servicio: registro.tipoServicio,
        quien_refiere: registro.quienRefiere,
        accion_realizada: registro.accion,
        excusa_maestros: registro.excusa,
        hora_salida: registro.horaSalida,
        notas_enfermeria: registro.notas,
        pcs: registro.pcs ? true : false,
        escuela: $('escuela').value,
        municipio: $('municipio').value,
        registrado_en: new Date().toISOString()
      };
      fetch(url, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).then(function() {
        if (!silencioso) toast('✓ Enviado a Google Sheets');
        resolve(true);
      }).catch(function(err) {
        if (!silencioso) toast('Error al enviar: ' + err.message, 'error');
        resolve(false);
      });
    });
  }

  function probarSheets() {
    var url = $('sheetsUrl').value.trim();
    if (!url) {
      toast('Ingresa primero la URL del Web App', 'error');
      return;
    }
    if (url.indexOf('script.google.com') === -1) {
      toast('La URL no parece ser de Google Apps Script', 'error');
      return;
    }
    var oldUrl = sheetsConfig.url;
    sheetsConfig.url = url;
    var prueba = {
      fecha: new Date().toISOString().split('T')[0],
      horaLlegada: '10:00',
      nombre: 'PRUEBA - Estudiante Test',
      grado: '8-2',
      tipoServicio: 'Cernimiento',
      quienRefiere: 'Prueba de conexión',
      accion: 'Registro de prueba desde Enfermería ALC',
      excusa: 'No',
      horaSalida: '10:15',
      pcs: true
    };
    enviarASheets(prueba, true).then(function(ok) {
      sheetsConfig.url = oldUrl;
      if (ok) {
        toast('✓ Prueba enviada. Revisa tu Google Sheets.');
      } else {
        toast('No se pudo enviar la prueba', 'error');
      }
    });
  }

  function enviarTodoASheets() {
    if (!sheetsConfig.url) {
      toast('Configura primero la URL en la pestaña Google Sheets', 'error');
      return;
    }
    var datos = getRegistrosExportar();
    if (datos.length === 0) {
      toast('No hay registros para enviar', 'error');
      return;
    }
    if (!confirm('¿Enviar ' + datos.length + ' registros a Google Sheets?')) return;
    toast('Enviando ' + datos.length + ' registros...', 'warning');
    
    var enviados = 0;
    var i = 0;
    function siguiente() {
      if (i >= datos.length) {
        toast('✓ Enviados ' + enviados + ' de ' + datos.length + ' a Google Sheets');
        return;
      }
      enviarASheets(datos[i], true).then(function(ok) {
        if (ok) enviados++;
        i++;
        setTimeout(siguiente, 250);
      });
    }
    siguiente();
  }

  // ===== CRUD =====
  function guardarRegistro() {
    var nombre = $('nombre').value.trim();
    if (!nombre) {
      toast('El nombre del estudiante es obligatorio', 'error');
      return;
    }
    var registro = {
      id: Date.now() + Math.random(),
      fecha: $('fecha').value,
      horaLlegada: $('horaLlegada').value,
      nombre: nombre,
      grado: $('grado').value,
      tipoServicio: $('tipoServicio').value,
      quienRefiere: $('quienRefiere').value,
      accion: $('accion').value,
      excusa: $('excusa').value,
      horaSalida: $('horaSalida').value,
      notas: $('notas').value,
      pcs: $('pcs').checked
    };
    registros.push(registro);
    guardar();
    limpiarFormulario();
    toast('✓ Registro guardado');
    renderHoy();
    renderHistorial();
    if (sheetsConfig.url && sheetsConfig.auto) {
      enviarASheets(registro, true).then(function(ok) {
        if (ok) toast('📊 También enviado a Google Sheets');
      });
    }
  }

  function limpiarFormulario() {
    var ids = ['nombre','grado','tipoServicio','quienRefiere','accion','horaSalida','notas'];
    for (var i = 0; i < ids.length; i++) $(ids[i]).value = '';
    $('excusa').value = 'No';
    $('pcs').checked = false;
    setHoraActual('horaLlegada');
  }

  window.eliminarRegistro = function(id) {
    if (!confirm('¿Eliminar este registro?')) return;
    registros = registros.filter(function(r) { return r.id !== id; });
    guardar();
    toast('Registro eliminado');
    renderHoy();
    renderHistorial();
  };

  window.editarRegistro = function(id) {
    var r = null;
    for (var i = 0; i < registros.length; i++) {
      if (registros[i].id === id) { r = registros[i]; break; }
    }
    if (!r) return;
    editingId = id;
    $('editFecha').value = r.fecha || '';
    $('editHoraLlegada').value = r.horaLlegada || '';
    $('editNombre').value = r.nombre || '';
    $('editGrado').value = r.grado || '';
    $('editTipoServicio').value = r.tipoServicio || '';
    $('editQuienRefiere').value = r.quienRefiere || '';
    $('editAccion').value = r.accion || '';
    $('editExcusa').value = r.excusa || 'No';
    $('editHoraSalida').value = r.horaSalida || '';
    $('editNotas').value = r.notas || '';
    $('editPcs').checked = !!r.pcs;
    $('modalEdit').classList.add('show');
  };

  function guardarEdicion() {
    var r = null;
    for (var i = 0; i < registros.length; i++) {
      if (registros[i].id === editingId) { r = registros[i]; break; }
    }
    if (!r) return;
    r.fecha = $('editFecha').value;
    r.horaLlegada = $('editHoraLlegada').value;
    r.nombre = $('editNombre').value.trim();
    r.grado = $('editGrado').value;
    r.tipoServicio = $('editTipoServicio').value;
    r.quienRefiere = $('editQuienRefiere').value;
    r.accion = $('editAccion').value;
    r.excusa = $('editExcusa').value;
    r.horaSalida = $('editHoraSalida').value;
    r.notas = $('editNotas').value;
    r.pcs = $('editPcs').checked;
    guardar();
    cerrarModal();
    toast('✓ Cambios guardados');
    renderHoy();
    renderHistorial();
  }

  function cerrarModal() {
    $('modalEdit').classList.remove('show');
    editingId = null;
  }

  window.marcarSalida = function(id) {
    var r = null;
    for (var i = 0; i < registros.length; i++) {
      if (registros[i].id === id) { r = registros[i]; break; }
    }
    if (!r) return;
    var ahora = new Date();
    r.horaSalida = String(ahora.getHours()).padStart(2,'0') + ':' + String(ahora.getMinutes()).padStart(2,'0');
    guardar();
    renderHoy();
    renderHistorial();
    toast('✓ Salida: ' + r.horaSalida);
  };

  // ===== RENDER =====
  function renderHoy() {
    var fecha = $('fecha').value;
    var lbl = $('fechaHoyLabel');
    if (lbl) lbl.textContent = fecha ? '— ' + formatearFecha(fecha) : '';

    var delDia = registros.filter(function(r) { return r.fecha === fecha; });
    delDia.sort(function(a,b) { return (a.horaLlegada||'').localeCompare(b.horaLlegada||''); });

    var conExcusa = delDia.filter(function(r) { return r.excusa && r.excusa !== 'No'; }).length;
    var conPCS = delDia.filter(function(r) { return r.pcs; }).length;
    var presentes = delDia.filter(function(r) { return !r.horaSalida; }).length;

    $('statsHoy').innerHTML =
      '<div class="stat-card"><div class="value">' + delDia.length + '</div><div class="label">Atendidos</div></div>' +
      '<div class="stat-card"><div class="value">' + conExcusa + '</div><div class="label">Con excusa</div></div>' +
      '<div class="stat-card"><div class="value">' + conPCS + '</div><div class="label">Con PCS</div></div>' +
      '<div class="stat-card"><div class="value">' + presentes + '</div><div class="label">Aún presentes</div></div>';

    var tbody = $('tbodyHoy');
    if (delDia.length === 0) {
      tbody.innerHTML = '<tr><td colspan="11" class="empty-state">No hay registros para esta fecha.</td></tr>';
      return;
    }
    var html = '';
    for (var i = 0; i < delDia.length; i++) {
      var r = delDia[i];
      html += '<tr>' +
        '<td>' + (r.horaLlegada || '-') + '</td>' +
        '<td><strong>' + escapar(r.nombre) + '</strong></td>' +
        '<td>' + escapar(r.grado || '-') + '</td>' +
        '<td>' + escapar(r.tipoServicio || '-') + '</td>' +
        '<td>' + escapar(r.quienRefiere || '-') + '</td>' +
        '<td>' + escapar(r.accion || '-') + '</td>' +
        '<td>' + escapar(r.excusa || 'No') + '</td>' +
        '<td>' + (r.horaSalida || '<button class="btn btn-sm btn-success no-print" onclick="marcarSalida(' + r.id + ')">🕐 Salir</button>') + '</td>' +
        '<td>' + escapar(r.notas || '-') + '</td>' +
        '<td style="text-align:center;">' + (r.pcs ? '<span class="pcs-badge">✓ PCS</span>' : '-') + '</td>' +
        '<td class="no-print action-cell">' +
          '<button class="btn btn-sm btn-warning" onclick="editarRegistro(' + r.id + ')">✏️</button>' +
          '<button class="btn btn-sm btn-danger" onclick="eliminarRegistro(' + r.id + ')">🗑️</button>' +
        '</td></tr>';
    }
    tbody.innerHTML = html;
  }

  function renderHistorial() {
    var nombre = $('searchNombre').value.toLowerCase();
    var fecha = $('searchFecha').value;
    var servicio = $('searchServicio').value;

    var filtrados = registros.filter(function(r) {
      if (nombre && (r.nombre || '').toLowerCase().indexOf(nombre) === -1) return false;
      if (fecha && r.fecha !== fecha) return false;
      if (servicio && r.tipoServicio !== servicio) return false;
      return true;
    });
    filtrados.sort(function(a,b) {
      var fa = (a.fecha || '') + (a.horaLlegada || '');
      var fb = (b.fecha || '') + (b.horaLlegada || '');
      return fb.localeCompare(fa);
    });

    var fechasUnicas = {};
    var estudiantes = {};
    for (var i = 0; i < filtrados.length; i++) {
      fechasUnicas[filtrados[i].fecha] = true;
      estudiantes[(filtrados[i].nombre || '').toLowerCase()] = true;
    }

    $('statsHistorial').innerHTML =
      '<div class="stat-card"><div class="value">' + filtrados.length + '</div><div class="label">Registros</div></div>' +
      '<div class="stat-card"><div class="value">' + Object.keys(estudiantes).length + '</div><div class="label">Estudiantes únicos</div></div>' +
      '<div class="stat-card"><div class="value">' + Object.keys(fechasUnicas).length + '</div><div class="label">Días registrados</div></div>';

    var tbody = $('tbodyHistorial');
    if (filtrados.length === 0) {
      tbody.innerHTML = '<tr><td colspan="12" class="empty-state">No se encontraron registros.</td></tr>';
      return;
    }
    var html = '';
    for (var k = 0; k < filtrados.length; k++) {
      var r = filtrados[k];
      html += '<tr>' +
        '<td>' + (r.fecha || '-') + '</td>' +
        '<td>' + (r.horaLlegada || '-') + '</td>' +
        '<td><strong>' + escapar(r.nombre) + '</strong></td>' +
        '<td>' + escapar(r.grado || '-') + '</td>' +
        '<td>' + escapar(r.tipoServicio || '-') + '</td>' +
        '<td>' + escapar(r.quienRefiere || '-') + '</td>' +
        '<td>' + escapar(r.accion || '-') + '</td>' +
        '<td>' + escapar(r.excusa || 'No') + '</td>' +
        '<td>' + (r.horaSalida || '-') + '</td>' +
        '<td>' + escapar(r.notas || '-') + '</td>' +
        '<td style="text-align:center;">' + (r.pcs ? '<span class="pcs-badge">✓ PCS</span>' : '-') + '</td>' +
        '<td class="no-print action-cell">' +
          '<button class="btn btn-sm btn-warning" onclick="editarRegistro(' + r.id + ')">✏️</button>' +
          '<button class="btn btn-sm btn-danger" onclick="eliminarRegistro(' + r.id + ')">🗑️</button>' +
        '</td></tr>';
    }
    tbody.innerHTML = html;
  }

  function limpiarFiltros() {
    $('searchNombre').value = '';
    $('searchFecha').value = '';
    $('searchServicio').value = '';
    renderHistorial();
  }

  // ===== EXPORTAR =====
  function getRegistrosExportar() {
    var desde = $('expDesde').value;
    var hasta = $('expHasta').value;
    var f = registros.slice();
    if (desde) f = f.filter(function(r) { return r.fecha >= desde; });
    if (hasta) f = f.filter(function(r) { return r.fecha <= hasta; });
    f.sort(function(a,b) {
      var fa = (a.fecha || '') + (a.horaLlegada || '');
      var fb = (b.fecha || '') + (b.horaLlegada || '');
      return fa.localeCompare(fb);
    });
    return f;
  }

  function exportarCSV() {
    var datos = getRegistrosExportar();
    if (datos.length === 0) {
      toast('No hay registros para exportar', 'error');
      return;
    }
    var headers = ['Fecha','Llegada','Estudiante','Grado','Tipo Servicio','Quien Refiere','Accion','Excusa','Salida','Notas Enfermeria','PCS'];
    var lines = [headers.join(',')];
    for (var i = 0; i < datos.length; i++) {
      var r = datos[i];
      var row = [r.fecha||'', r.horaLlegada||'', r.nombre||'', r.grado||'', r.tipoServicio||'', r.quienRefiere||'', r.accion||'', r.excusa||'', r.horaSalida||'', r.notas||'', r.pcs?'Sí':'No'];
      lines.push(row.map(function(v) { return '"' + String(v).replace(/"/g,'""') + '"'; }).join(','));
    }
    var csv = '\uFEFF' + lines.join('\n');
    var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'enfermeria_' + new Date().toISOString().split('T')[0] + '.csv';
    a.click();
    URL.revokeObjectURL(url);
    toast('✓ CSV descargado');
  }

  function exportarTexto() {
    var datos = getRegistrosExportar();
    if (datos.length === 0) {
      toast('No hay registros', 'error');
      return;
    }
    var t = 'LISTA DIARIA DE ESTUDIANTES ATENDIDOS EN ENFERMERÍA\n';
    t += 'Escuela: ' + $('escuela').value + '\n';
    t += 'Municipio: ' + $('municipio').value + '\n\n';
    t += 'Fecha\tLlegada\tEstudiante\tGrado\tServicio\tRefiere\tAcción\tExcusa\tSalida\tNotas\tPCS\n';
    for (var i = 0; i < datos.length; i++) {
      var r = datos[i];
      t += (r.fecha||'') + '\t' + (r.horaLlegada||'') + '\t' + (r.nombre||'') + '\t' + (r.grado||'') + '\t' + (r.tipoServicio||'') + '\t' + (r.quienRefiere||'') + '\t' + (r.accion||'') + '\t' + (r.excusa||'') + '\t' + (r.horaSalida||'') + '\t' + (r.notas||'') + '\t' + (r.pcs?'Sí':'No') + '\n';
    }
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(t).then(function() {
        toast('✓ Copiado al portapapeles');
      }).catch(function() {
        toast('No se pudo copiar', 'error');
      });
    } else {
      toast('Tu navegador no permite copiar automáticamente', 'error');
    }
  }

  function imprimirHoy() {
    // Cambiar a la pestaña Hoy
    cambiarTab('hoy');
    
    // Preparar el encabezado de impresión con el mes
    var fecha = $('fecha').value;
    var meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    var hoy = fecha ? new Date(fecha + 'T12:00:00') : new Date();
    var mesTexto = meses[hoy.getMonth()] + ' ' + hoy.getFullYear();
    var fechaCompleta = hoy.getDate() + ' de ' + meses[hoy.getMonth()].toLowerCase() + ' de ' + hoy.getFullYear();
    
    var printMes = $('printMes');
    if (printMes) {
      printMes.textContent = 'Mes: ' + mesTexto + ' · Fecha del registro: ' + fechaCompleta;
    }
    
    // Marcar el tab activo para impresión
    var tabHoy = $('tab-hoy');
    if (tabHoy) tabHoy.classList.add('print-active');
    
    // Verificar si hay registros antes de imprimir
    var fechaActual = $('fecha').value;
    var delDia = registros.filter(function(r) { return r.fecha === fechaActual; });
    
    if (delDia.length === 0) {
      toast('No hay registros para imprimir en esta fecha', 'warning');
      if (tabHoy) tabHoy.classList.remove('print-active');
      return;
    }
    
    setTimeout(function() {
      window.print();
      // Limpiar después de imprimir
      setTimeout(function() {
        if (tabHoy) tabHoy.classList.remove('print-active');
      }, 500);
    }, 400);
  }

  function borrarTodo() {
    if (!confirm('¿BORRAR TODOS los registros? No se puede deshacer.')) return;
    if (!confirm('Última advertencia: ' + registros.length + ' registros. ¿Continuar?')) return;
    registros = [];
    guardar();
    renderHoy();
    renderHistorial();
    toast('Todos los registros eliminados');
  }

  // ===== INICIALIZACIÓN =====
  function init() {
    try {
      var saved = localStorage.getItem('enfermeriaRegistros');
      if (saved) registros = JSON.parse(saved);
    } catch(e) { registros = []; }

    try {
      var savedS = localStorage.getItem('enfermeriaSheets');
      if (savedS) sheetsConfig = JSON.parse(savedS);
    } catch(e) {}

    if ($('sheetsUrl')) $('sheetsUrl').value = sheetsConfig.url || '';
    if ($('sheetsAuto')) $('sheetsAuto').checked = !!sheetsConfig.auto;
    actualizarIndicadorSheets();

    var hoy = new Date().toISOString().split('T')[0];
    $('fecha').value = hoy;
    setHoraActual('horaLlegada');

    // Tabs
    var tabs = document.querySelectorAll('.tab');
    for (var i = 0; i < tabs.length; i++) {
      (function(btn) {
        btn.addEventListener('click', function() {
          cambiarTab(btn.getAttribute('data-tab'));
        });
      })(tabs[i]);
    }

    // Botones del formulario principal
    $('btnGuardar').addEventListener('click', guardarRegistro);
    $('btnLimpiar').addEventListener('click', limpiarFormulario);
    $('btnHoraLlegada').addEventListener('click', function() { setHoraActual('horaLlegada'); });
    $('btnHoraSalida').addEventListener('click', function() { setHoraActual('horaSalida'); });

    // Filtros
    $('searchNombre').addEventListener('input', renderHistorial);
    $('searchFecha').addEventListener('change', renderHistorial);
    $('searchServicio').addEventListener('change', renderHistorial);
    $('btnLimpiarFiltros').addEventListener('click', limpiarFiltros);
    $('fecha').addEventListener('change', renderHoy);

    // Exportar
    $('btnExpCsv').addEventListener('click', exportarCSV);
    $('btnExpTexto').addEventListener('click', exportarTexto);
    $('btnImprimir').addEventListener('click', imprimirHoy);
    $('btnEnviarTodo').addEventListener('click', enviarTodoASheets);
    $('btnBorrarTodo').addEventListener('click', borrarTodo);

    // Google Sheets
    $('btnGuardarSheets').addEventListener('click', guardarConfigSheets);
    $('btnProbarSheets').addEventListener('click', probarSheets);
    $('btnDesconectarSheets').addEventListener('click', desconectarSheets);
    $('btnEnviarTodoSheets').addEventListener('click', enviarTodoASheets);

    // Modal
    $('btnGuardarEdicion').addEventListener('click', guardarEdicion);
    $('btnCerrarModal').addEventListener('click', cerrarModal);

    renderHoy();
    renderHistorial();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

</body>
</html>
